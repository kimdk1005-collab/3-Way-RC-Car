        <mxCell id="7" value="&lt;b&gt;c &amp;lt; 25 cm ?&lt;/b&gt;&lt;br&gt;전방 장애물" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#7A5D00;fontFamily=Arial;fontSize=14;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="445" width="240" height="110" as="geometry" />

        <mxCell id="8" value="&lt;b&gt;l ≥ r ?&lt;/b&gt;&lt;br&gt;좌측 공간이 더 넓음" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#7A5D00;fontFamily=Arial;fontSize=13;strokeWidth=2;" vertex="1" parent="1">

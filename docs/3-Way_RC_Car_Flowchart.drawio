  <diagram id="page-3" name="03_물리 컨트롤러 흐름">
    <mxGraphModel dx="1420" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="&lt;b&gt;Physical Controller — Joystick · Button · UART 명령 생성 흐름&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Arial;fontSize=27;fontColor=#102A43;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="48" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Controller STM32F411CEU6 · ADC Scan + Circular DMA · 50 ms 입력 루프" style="text;html=1;align=left;verticalAlign=middle;fontFamily=Arial;fontSize=14;fontColor=#627D98;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="40" y="68" width="1320" height="28" as="geometry" />

        <mxCell id="5" value="&lt;b&gt;sensorMutex로 거리값 복사&lt;/b&gt;&lt;br&gt;l = dist_L · c = dist_C · r = dist_R" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F7F4;strokeColor=#3A9D85;fontColor=#087F5B;fontFamily=Arial;fontSize=14;arcSize=12;strokeWidth=2;" vertex="1" parent="1">

        <mxCell id="4" value="&lt;b&gt;컨트롤러 전원 ON&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#9B1C1C;strokeColor=#9B1C1C;fontColor=#FFFFFF;fontFamily=Arial;fontSize=14;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="90" y="125" width="240" height="58" as="geometry" />
        </mxCell>
        <mxCell id="5" value="&lt;b&gt;주변장치 초기화&lt;/b&gt;&lt;br&gt;GPIO · DMA2 · ADC1 · USART1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE5E5;strokeColor=#D76A6A;fontColor=#9B1C1C;fontFamily=Arial;fontSize=14;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="225" width="280" height="75" as="geometry" />
        </mxCell>
        <mxCell id="6" value="&lt;b&gt;ADC1 Circular DMA 시작&lt;/b&gt;&lt;br&gt;adc_buf[0..3]에 12-bit 값 연속 수집" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D76A6A;fontColor=#334E68;fontFamily=Arial;fontSize=13;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="65" y="345" width="290" height="78" as="geometry" />
        </mxCell>
        <mxCell id="7" value="&lt;b&gt;최신 입력 읽기&lt;/b&gt;&lt;br&gt;joy1_y = adc_buf[1]&lt;br&gt;joy2_x = adc_buf[2]&lt;br&gt;PB12 / PB13 버튼 상태" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#829AB1;fontColor=#334E68;fontFamily=Arial;fontSize=13;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="475" width="300" height="102" as="geometry" />
        </mxCell>
        <mxCell id="8" value="&lt;b&gt;PB12 Falling Edge?&lt;/b&gt;&lt;br&gt;Joystick 1 버튼" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#7A5D00;fontFamily=Arial;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="455" y="150" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="9" value="&lt;b&gt;&#39;H&#39; 전송&lt;/b&gt;&lt;br&gt;400 ms 경적" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D6B656;fontColor=#7A5D00;fontFamily=Arial;fontSize=13;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="755" y="165" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="10" value="&lt;b&gt;PB13 Falling Edge?&lt;/b&gt;&lt;br&gt;Joystick 2 버튼" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#7A5D00;fontFamily=Arial;fontSize=13;strokeWidth=2;" vertex="1" parent="1">

        </mxCell>
        <mxCell id="9" value="&lt;b&gt;제자리 좌회전&lt;/b&gt;&lt;br&gt;motor_spin_left(450)&lt;br&gt;light_dir = &#39;l&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D8F3ED;strokeColor=#3A9D85;fontColor=#087F5B;fontFamily=Arial;fontSize=13;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
